
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}


enum OrderStatus {
  pending 
  confirm
  preparing
  served
  completed
  cancelled
}

enum UserRole {
  owner
  manager 
  front_staff
  cashier
  kitchen
}

enum TableStatus {
  available
  occupied 
  reserved 
}

enum PaymentStatus {
  pending
  paid
  failed
  refunded
}

model Company {
  id        String   @id @default(cuid())
  name      String
  subscription String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  restaurants Restaurant[]
}

model Restaurant {
  id         String   @id @default(cuid())
  name       String
  companyId  String
  company    Company @relation(fields: [companyId], references: [id])
  branches   Branch[]
  user       User[]

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Branch {
  id           String   @id @default(cuid())
  name         String
  location     String?

  restaurantId String
  restaurant Restaurant @relation(fields: [restaurantId], references: [id])

  zone      Zone[]
  user      User[]
  tables   Table[]
  menus    Menu[]
  orders   Order[]
  paymentMethods PaymentMethod[]

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model User {
  id            String      @id @default(cuid())
  name          String
  username      String      @unique
  email         String      @unique
  hashedPassword String
  hashedPin      String
  role          UserRole
  
  branchId       String?
  branch         Branch?  @relation(fields: [branchId], references: [id])

  restaurantId  String?
  restaurant    Restaurant? @relation(fields: [restaurantId], references: [id])

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Zone {
   id            String      @id @default(cuid())
  name          String

  branchId       String?
  branch         Branch?  @relation(fields: [branchId], references: [id])

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  tables        Table[]
}

model Table {
  id            String        @id @default(cuid())
  tableNumber   String
  capacity      Int
  status        TableStatus   @default(available)
  session       Boolean
  qr            String @unique

  branchId       String?
  branch         Branch?  @relation(fields: [branchId], references: [id])

  zoneId         String
  zone          Zone @relation(fields: [zoneId], references: [id])

  order       Order[]
  payment     Payment[]
  tableSession tableSession[]

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  @@unique([branchId, tableNumber])
}

model tableSession {
  id            String  @id @default(cuid())

  tableId       String
  table      Table @relation (fields: [tableId] , references: [id])

  sessionStatus     Boolean
  startAt           DateTime @default(now())
  endAt             DateTime?

  orders Order[]
  payments Payment[]

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model Menu {
  id        String   @id @default(cuid())
  name      String

  branchId  String
  branch Branch @relation(fields: [branchId], references: [id])

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  categories Category[]
}

model Category {
  id     String @id @default(cuid())
  name   String

  menuId String
  menu Menu @relation(fields: [menuId], references: [id])

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  items MenuItem[]
}

model MenuItem {
  id          String  @id @default(cuid())
  name        String
  price       Decimal
  description String?
  imageUrl    String?

  categoryId String
  category Category @relation(fields: [categoryId], references: [id])

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  orderItems OrderItem[]
}

model Order {
  id         String      @id @default(cuid())
  branchId   String
  tableId    String?
  sessionId  String?

  status OrderStatus @default(pending)

  totalAmount Decimal @default(0)

  branch   Branch   @relation(fields: [branchId], references: [id])
  table    Table?   @relation(fields: [tableId], references: [id])
  session  tableSession? @relation( fields: [sessionId] , references: [id])

  items   OrderItem[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  menuItemId String
  quantity  Int
  price     Decimal

  order    Order    @relation(fields: [orderId], references: [id])
  menuItem MenuItem @relation(fields: [menuItemId], references: [id])

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model PaymentMethod {
  id        String @id @default(cuid())
  name      String

  branchId   String
  branch    Branch @relation( fields: [branchId], references: [id])
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  payment    Payment[]
}

model Payment {
  id        String @id @default(cuid())
  tableId   String 
  sessionId String

  amount    Decimal
  status    PaymentStatus @default(pending)
  methodId    String? // cash, card, qr
  paymentmethod  PaymentMethod? @relation( fields: [methodId], references: [id])

  table Table @relation(fields: [tableId], references: [id])
  session tableSession @relation( fields: [sessionId], references: [id])

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}






