generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}


model Company {
  id           String       @id @default(cuid())
  name         String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  owner        Owner[]
  restaurant   Restaurant[]
}

  model Owner {
  id             String      @id @default(cuid())
  name           String
  email          String      @unique
  role           String
  username       String      @unique
  hashedPassword String
  hashedPin      String
  companyId      String
  subscription   subscriptionPlan 
  company        Company @relation(fields:[companyId], references:[id])
  restaurant     Restaurant[]
  branch         Branch[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model Restaurant {
  id        String   @id @default(cuid())
  name      String
  companyId String
  company Company @relation(fields: [companyId], references: [id])
  ownerId   String
  owner     Owner @relation(fields: [ownerId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  branches  Branch[]
  staff      Staff[]
}

model Branch {
  id             String          @id @default(cuid())
  name           String
  location       String?
  ownerId        String
  restaurantId   String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  restaurant     Restaurant      @relation(fields: [restaurantId], references: [id])
  owner          Owner           @relation(fields: [ownerId], references: [id])
  menus          Menu[]
  orders         Order[]
  paymentMethods PaymentMethod[]
  tables         Table[]
  staff           Staff[]
  zone           Zone[]
}

model Zone {
  id        String   @id @default(cuid())
  name      String
  branchId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tables    Table[]
  branch    Branch?  @relation(fields: [branchId], references: [id])
  staff     Staff[]
}

model Staff {
  id             String      @id @default(cuid())
  name           String
  email          String      @unique
  role           StaffRole
  restaurantId   String
  branchId       String
  zoneId         String
  username       String      @unique
  hashedPassword String
  hashedPin      String
  status         Boolean    @default(true)
  restaurant     Restaurant @relation(fields: [restaurantId], references: [id])
  branch         Branch     @relation(fields: [branchId], references: [id])
  zone           Zone       @relation(fields: [zoneId], references: [id])
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model Table {
  id           String         @id @default(cuid())
  tableNumber  String
  capacity     Int
  status       TableStatus    @default(available)
  session      Boolean
  qr           String         @unique
  branchId     String
  zoneId       String
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  order        Order[]
  payment      Payment[]
  branch       Branch        @relation(fields: [branchId], references: [id])
  zone         Zone           @relation(fields: [zoneId], references: [id])
  tableSession tableSession[]

  @@unique([branchId, tableNumber])
}

model tableSession {
  id            String    @id @default(cuid())
  tableId       String
  sessionStatus Boolean
  startAt       DateTime  @default(now())
  endAt         DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  orders        Order[]
  payments      Payment[]
  table         Table     @relation(fields: [tableId], references: [id])
}

model Menu {
  id         String     @id @default(cuid())
  name       String
  branchId   String
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  categories Category[]
  branch     Branch     @relation(fields: [branchId], references: [id])
}

model Category {
  id        String     @id @default(cuid())
  name      String
  menuId    String
  description String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  menu      Menu       @relation(fields: [menuId], references: [id])
  items     MenuItem[]
}

model MenuItem {
  id          String      @id @default(cuid())
  name        String
  price       Decimal
  description String?
  imageUrl    String?
  categoryId  String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  category    Category    @relation(fields: [categoryId], references: [id])
  orderItems  OrderItem[]
}

model Order {
  id          String        @id @default(cuid())
  branchId    String
  tableId     String?
  sessionId   String?
  status      OrderStatus   @default(pending)
  totalAmount Decimal       @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  branch      Branch        @relation(fields: [branchId], references: [id])
  session     tableSession? @relation(fields: [sessionId], references: [id])
  table       Table?        @relation(fields: [tableId], references: [id])
  items       OrderItem[]
}

model OrderItem {
  id         String   @id @default(cuid())
  orderId    String
  menuItemId String
  quantity   Int
  price      Decimal
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
  order      Order    @relation(fields: [orderId], references: [id])
}

model PaymentMethod {
  id        String    @id @default(cuid())
  name      String
  branchId  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  payment   Payment[]
  branch    Branch    @relation(fields: [branchId], references: [id])
}

model Payment {
  id            String         @id @default(cuid())
  tableId       String
  sessionId     String
  amount        Decimal
  status        PaymentStatus  @default(pending)
  methodId      String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  paymentmethod PaymentMethod? @relation(fields: [methodId], references: [id])
  session       tableSession   @relation(fields: [sessionId], references: [id])
  table         Table          @relation(fields: [tableId], references: [id])
}

enum OrderStatus {
  pending
  confirm
  preparing
  served
  completed
  cancelled
}

enum StaffRole {
  owner
  manager
  front_staff
  cashier
  kitchen
}

enum TableStatus {
  available
  occupied
  reserved
}

enum PaymentStatus {
  pending
  paid
  failed
  refunded
}

enum subscriptionPlan {
  free
  basic
  bronze
  silver
  gold
  }
